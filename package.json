{
  "name": "spirefall",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest --run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "goldens:update": "UPDATE_GOLDENS=1 vitest --run src/engine/__tests__/goldens.test.ts",
    "fuzz:builds": "FUZZ_POP=20 FUZZ_GENS=5 FUZZ_BUDGETS=0,5000,8000,14000 FUZZ_SEEDS=alpha,beta,gamma,delta vitest --run src/harness/__tests__/fuzz.test.ts",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run typecheck && npm run test:unit && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.3.0",
    "globals": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.1.11",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
